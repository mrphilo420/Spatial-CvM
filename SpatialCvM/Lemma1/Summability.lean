-- ============================================================================
-- SECTION 3: Non-Vanishing Variance (Step 3 of Lemma 1)
-- ============================================================================

/-- Non-vanishing variance at diagonal (completes Lemma 1, part b).

    Status: PROVED - Uses existing axiom kernel_squared_integral_pos

    Theorem: Γ(0,0) > 0

    Proof:
    1. γ_0(0,0) = ∫ K_h(v)² dv > 0
    2. This is positive from IsKernel (non-degenerate on support).

    The "fixed bandwidth" assumption is crucial: if h → 0, then
    γ_0(0,0) → 0 and the non-degeneracy fails.
    -/

theorem Gamma_diagonal_positive (K : ℝ → ℝ) {α : ℝ → ℝ} (h_mix : AlphaMixing α)
    (h : ℝ) (hh : h > 0) (hK : IsKernel K) :
    gamma_kernel K h hh 0 > 0 := by
  exact kernel_squared_integral_pos K h hh hK

-- ============================================================================
-- SECTION 4: Continuity of Covariance
-- ============================================================================

/-- The covariance function Γ(y,z) is continuous in (y,z).

    Status: Axiomatized - Requires kernel Lipschitz continuity

    This follows from:
    1. The kernel K_h is Lipschitz (from IsKernel)
    2. Each γ_d(y,z) depends continuously on (y,z) via kernel values
    3. The series converges uniformly by summability
    -/

axiom Gamma_continuous (K : ℝ → ℝ) {α : ℝ → ℝ} (h_mix : AlphaMixing α)
    (h : ℝ) (hh : h > 0) (hK : IsKernel K) :
    ∀ ε > 0, ∃ δ > 0, ∀ y₁ y₂ z₁ z₂ : ℝ,
      |y₁ - y₂| < δ → |z₁ - z₂| < δ →
      |gamma_kernel K h hh (y₁ - z₁) - gamma_kernel K h hh (y₂ - z₂)| < ε

