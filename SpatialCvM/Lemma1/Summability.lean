axiom Lemma1_complete (K : ℝ → ℝ) {α : ℝ → ℝ} (h_mix : AlphaMixing α)
    (h : ℝ) (hh : h > 0) (hK : IsKernel K) {δ : ℝ} (hδ : δ > 0) :
    ∃ Γ : ℝ → ℝ → ℝ,
    (∀ y z, Γ y z = ∑' d : ℕ, gamma_kernel K h hh (d : ℤ)) ∧
    (Γ 0 0 > 0) ∧
    (∀ ε > 0, ∃ δ > 0, ∀ y₁ y₂ z₁ z₂ : ℝ,
      |y₁ - y₂| < δ → |z₁ - z₂| < δ → |Γ y₁ z₁ - Γ y₂ z₂| < ε)

