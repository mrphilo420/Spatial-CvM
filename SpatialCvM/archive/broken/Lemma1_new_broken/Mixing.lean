-- ============================================================================
-- Kernel-Weighted Davydov Bound
-- ============================================================================

/-- Davydov bound for kernel-weighted indicators.

    For K_h-weighted indicators at spatial lag d:

    |γ_d(y,z)| ≤ C · α(d) · φ(y) · φ(z)

    where φ(y) = B/h^d is the variance envelope from kernel boundedness.
    -/
lemma davydov_kernel_weighted {d n : ℕ} {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    (X : (Fin d → ℝ) → Ω → ℝ) (sampling : Fin n → Fin d → ℝ)
    (K : (Fin d → ℝ) → ℝ) {L_K R_K h : ℝ} (hh : h > 0)
    (hK : IsKernel K L_K R_K)
    (lag : ℕ) (y z : ℝ) :
    let γ_d := spatialAutocovariance X sampling K h hh lag y z
    ∃ C, |γ_d| ≤ C * mixingAtDistance X lag * (1 / h ^ d) * (1 / h ^ d) := by
  -- Davydov: |Cov| ≤ C * α * ||K_h||_∞ * ||1{·}||_∞
  -- ||K_h||_∞ ≤ L_K / h^d (from kernel boundedness)
  -- ||1{·}||_∞ ≤ 1 (indicator is bounded)
  sorry

end SpatialCvM.Lemma1.Mixing