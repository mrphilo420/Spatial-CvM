-- ============================================================================
-- σ-Algebra Inclusion for Measurable Functions
--
-- Key Insight (from StackExchange/Davide Giraudo):
-- If f is Borel measurable, then σ(f(X)) ⊆ σ(X).
--
-- This is crucial because:
-- 1. Indicators 1{X ≤ x} = f(X) where f = indicator (-∞,x]
-- 2. f is Borel measurable, so indicator inherits σ(X) membership
-- 3. Davydov's inequality applies directly without complex σ-algebra arguments
-- ============================================================================

/-- σ-algebra inclusion: σ(f(X)) ⊆ σ(X) when f is Borel measurable.

    Mathematical Content:
    For any Borel measurable f: ℝ → ℝ and random variable X,
    the σ-algebra generated by f(X) is contained in σ(X).

    Proof:
    {f(X) ∈ B} = {X ∈ f⁻¹(B)} where f⁻¹(B) is Borel.
    Therefore, f(X) is σ(X)-measurable.

    In Mathlib, this is `Measurable.comp`: if X is σ(X)-measurable
    and f is Borel-measurable, then f(X) is σ(X)-measurable.

    Reference: Standard measure theory (Bilingsley, Probability and Measure)
    -/
def sigma_algebra_inclusion {Ω : Type*} [MeasurableSpace Ω] {X : Ω → ℝ}
    (hX : Measurable X) (f : ℝ → ℝ) (hf : Measurable f) :
    Measurable (f ∘ X) := by
  exact hf.comp hX

/-- Indicator function 1{X ≤ x} is σ(X)-measurable.

    Mathematical Content:
    Let g(y) = 1{y ≤ x}, the indicator of (-∞, x]. Then:
    - g is Borel measurable (measurable_set_Iic)
    - 1{X ≤ x} = g(X)
    - By σ-algebra inclusion: σ(g(X)) ⊆ σ(X)
    - Therefore 1{X ≤ x} is σ(X)-measurable

    This is crucial for Davydov's inequality: when we consider the
    covariance of indicators, they inherit the σ(X) measurability
    from the underlying field X.
    -/
def indicator_measurable {Ω : Type*} [MeasurableSpace Ω] {X : Ω → ℝ}
    (hX : Measurable X) (x : ℝ) :
    Measurable (fun ω ↦ Set.indicator {ω' | X ω' ≤ x} (fun _ ↦ (1 : ℝ)) ω) := by
  apply Measurable.indicator
  · exact measurable_const
  · exact measurableSet_le hX measurable_const

/-- Centered indicator ξ(x) = 1{X ≤ x} - F(x) is σ(X)-measurable.

    Mathematical Content:
    - 1{X ≤ x} is σ(X)-measurable (by `indicator_measurable`)
    - F(x) = P(X ≤ x) is a constant (non-random)
    - Subtracting a constant preserves measurability
    - Therefore ξ(X,x) is σ(X)-measurable

    This is the standard "centered indicator" used in empirical process theory.
    The centering ensures E[ξ(X,x)] = 0.
    -/
def centered_indicator_measurable {Ω : Type*} [MeasurableSpace Ω] {μ : Measure Ω}
    {X : Ω → ℝ} (hX : Measurable X) (x : ℝ) :
    Measurable (fun ω ↦ Set.indicator {ω' | X ω' ≤ x} (fun _ ↦ 1 : Ω → ℝ) ω - (μ (X ⁻¹' Set.Iic x)).toReal) := by
  apply Measurable.sub
  · apply Measurable.indicator
    · exact measurable_const
    · exact measurableSet_le hX measurable_const
  · exact measurable_const

-- ============================================================================
-- L^2 Bound for Centered Indicators
--
-- Mathematical Insight (from Rio 2013, Theorem 1.1):
-- For centered indicator ξ = 1{X ≤ x} - F(x):
--   ‖ξ‖₂ ≤ 1  (since |ξ| ≤ 1 a.s.)
--   ‖ξ‖_p ≤ 1 for all p ≥ 1 (indicators are bounded by 1)
--
-- This is the key insight for Davydov's inequality: bounded random variables
-- have trivial L^p bounds, making the inequality apply directly.
-- ============================================================================

/-- Centered indicators are essentially bounded by 1.

    Mathematical fact: |ξ(ω)| = |1{X(ω) ≤ x} - F(x)| ≤ 1 a.s.

    Proof: 0 ≤ 𝟙{X ≤ x} ≤ 1 and 0 ≤ F(x) ≤ 1, so their difference ∈ [-1, 1].
    -/
lemma indicator_centered_abs_bound {Ω : Type*} [MeasurableSpace Ω] {μ : Measure Ω}
    [IsProbabilityMeasure μ] {X : Ω → ℝ} (x : ℝ) (ω : Ω) :
    |Set.indicator {ω' | X ω' ≤ x} (fun _ => 1 : Ω → ℝ) ω - (μ (X ⁻¹' Set.Iic x)).toReal| ≤ 1 := by
  have h1 : 0 ≤ Set.indicator {ω' | X ω' ≤ x} (fun _ => 1 : Ω → ℝ) ω := by
    apply Set.indicator_nonneg
    intro ω' hω'
    exact zero_le_one
  have h2 : Set.indicator {ω' | X ω' ≤ x} (fun _ => 1 : Ω → ℝ) ω ≤ 1 := by
    apply Set.indicator_le (fun _ _ ↦ by rfl)
    exact fun _ _ ↦ zero_le_one
  have h3 : 0 ≤ (μ (X ⁻¹' Set.Iic x)).toReal := by
    apply ENNReal.toReal_nonneg
  have h4 : (μ (X ⁻¹' Set.Iic x)).toReal ≤ 1 := by
    have : μ (X ⁻¹' Set.Iic x) ≤ μ Set.univ := μ.mono (by simp)
    rw [IsProbabilityMeasure.measure_univ] at this
    exact (ENNReal.toReal_le_toReal (by simp) (by simp)).mpr this
  apply abs_le.mpr
  constructor
  · linarith
  · linarith

-- ============================================================================
-- Davydov's Inequality (Step 1 of Proof)
-- ============================================================================

/-- Davydov's inequality for bounded measurable functions.

    Theorem (Davydov 1968/1993):
    For α-mixing processes, if f ∈ L^∞(𝒜) and g ∈ L^∞(ℬ):

    |Cov(f, g)| ≤ 12 · α(𝒜,ℬ)^{1-1/p-1/q} · ||f||_p · ||g||_q

    where 1/p + 1/q < 1.

    For bounded functions with p = q = ∞:
    |Cov(f, g)| ≤ C · α(𝒜,ℬ) · ||f||_∞ · ||g||_∞

    This is the key covariance bound for establishing summability.
    -/
def davydov_inequality {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    {𝒜 ℬ : MeasurableSpace Ω} (f g : Ω → ℝ)
    (hf : Measurable[𝒜] f) (hg : Measurable[ℬ] g)
    (hb1 : ∀ ω, |f ω| ≤ B1) (hb2 : ∀ ω, |g ω| ≤ B2)
    (α : ℝ) (hα : α = strongMixingCoefficient 𝒜 ℬ) :
    |cov[ℙ] f g| ≤ 12 * α * B1 * B2 := by
  -- Standard Davydov bound with explicit constant 12
  -- See Rio (2013) or Bradley (2005) for proof
  sorry

/-- Davydov-Rio inequality with L^p optimization (Rio 2013, Theorem 1.1).

    For centered indicators with p = 2 + δ, q = 2 + δ (conjugate exponents):

    |Cov(ξ_i, ξ_j)| ≤ 4 · α(d)^{δ/(2+δ)} · ||ξ_i||_{2+δ} · ||ξ_j||_{2+δ}

    For bounded centered indicators, ||ξ||_{2+δ} ≤ 1 (since |ξ| ≤ 1 a.s.).

    Therefore: |Cov(ξ_i, ξ_j)| ≤ 4 · α(d)^{δ/(2+δ)}

    The exponent δ/(2+δ) > 0 is the Rio/Davydov exponent, sharper than
    the classical L^∞ bound with exponent 1.

    Reference: Rio (2013), Theorem 1.1; Dehling-Taqqu (1989) for Hermite rank context.
    -/
def davydov_rio_inequality {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    {𝒜 ℬ : MeasurableSpace Ω} (f g : Ω → ℝ) (δ : ℝ) (hδ : δ > 0)
    (hf : Measurable[𝒜] f) (hg : Measurable[ℬ] g)
    (hb1 : ∀ ω, |f ω| ≤ 1) (hb2 : ∀ ω, |g ω| ≤ 1)  -- Bounded by 1 for indicators
    (α : ℝ) (hα : α = strongMixingCoefficient 𝒜 ℬ) (hαpos : α ≥ 0) :
    |cov[ℙ] f g| ≤ 4 * (α ^ (δ / (2 + δ))) := by
  -- Rio/Davydov bound optimized for L^{2+δ} spaces
  -- Exponent: 1 - 1/(2+δ) - 1/(2+δ) = δ/(2+δ)
  -- Constant: 4 (Rio 2013, optimal for this setting)
  --
  -- RESEARCH LEVEL: Requires Mathlib L^p moment infrastructure for full proof.
  -- Current status: AXIOMATIZED with correct exponent structure.
  --
  -- Note: For δ → 0, exponent → 0 (classical case).
  --       For δ → ∞, exponent → 1 (L^∞ case with ||·||_∞ ≤ 1).
  sorry

/-- Davydov's inequality applied to centered indicators.

    For indicators ξ_i = 1{X(s_i) ≤ y} - F(y) and ξ_j = 1{X(s_j) ≤ z} - F(z):

    |Cov(ξ_i, ξ_j)| ≤ C · α(dist(s_i, s_j)) · 1 · 1

    since ||ξ||_∞ ≤ 1 by `indicator_centered_abs_bound`.
    -/
def davydov_indicators {d : ℕ} {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
