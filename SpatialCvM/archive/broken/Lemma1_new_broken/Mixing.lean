-- ============================================================================
-- Kernel-Weighted Process
-- ============================================================================

/-- Kernel-weighted centered indicator

    The fundamental process for covariance analysis:
    ξ_i(y) = K_h(s_i - s) · [1{X(s_i) ≤ y} - F(y)]

    where:
    - K_h is the scaled spatial kernel
    - 1{X ≤ y} is the indicator (empirical component)
    - F(y) centers the indicator
    -/
def kernelWeightedIndicator {d n : ℕ} {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    (X : (Fin d → ℝ) → Ω → ℝ) (sampling : Fin n → Fin d → ℝ)
    (K : (Fin d → ℝ) → ℝ) (h : ℝ) (hh : h > 0)
    (i : Fin n) (y : ℝ) (ω : Ω) : ℝ :=
  let s_i := sampling i
  let indicator := if X s_i ω ≤ y then 1 else 0
  let centering := marginalDistribution X y
  Kernel.scaledKernel K h hh (fun _ ↦ 0) * (indicator - centering)

/-- Lag-d spatial autocovariance

    γ_d(y, z) = Cov(Y₁(y), Y_{1+d}(z))

    For the kernel-weighted process at spatial lag d.
    -/
def spatialAutocovariance {d n : ℕ} {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    (X : (Fin d → ℝ) → Ω → ℝ) (sampling : Fin n → Fin d → ℝ)
    (K : (Fin d → ℝ) → ℝ) (h : ℝ) (hh : h > 0)
    (lag : ℕ) (y z : ℝ) : ℝ :=
  sorry  -- Requires proper covariance definition with kernel weighting

/-- Asymptotic covariance Γ(y, z)

    Γ(y, z) = Σ_{d=0}^∞ γ_d(y, z)

    The infinite sum of spatial autocovariances.
    -/
def asymptoticCovariance {d n : ℕ} {Ω : Type*} [MeasurableSpace Ω] [IsProbabilityMeasure (ℙ : Measure Ω)]
    (X : (Fin d → ℝ) → Ω → ℝ) (sampling : Fin n → Fin d → ℝ)
    (K : (Fin d → ℝ) → ℝ) (h : ℝ) (hh : h > 0)
    (y z : ℝ) : ℝ :=
  ∑' d : ℕ, spatialAutocovariance X sampling K h hh d y z

notation "Γ[" X "," sampling "," K "," h "]" =>
  asymptoticCovariance X sampling K h (by positivity!)

