noncomputable def empiricalCov (L : SpatLat) (X : Loc → Ω → ℝ) (K : Loc → ℝ)
    (s₀ : Loc) (h : ℝ) (x y : ℝ) (P : Measure Ω) : ℝ :=
  ProbabilityTheory.covariance (F_hat L X K s₀ h x) (F_hat L X K s₀ h y) P

/-- Stationarity: translation invariance of joint distributions

A random field is stationary if its statistical properties don't depend
on absolute location, only on relative positions.

**Mathematical Definition**:
For all s, t ∈ ℝ² and measurable A ⊆ ℝ² × ℝ²:
  P((X₀, X_t) ∈ A) = P((X_s, X_{s+t}) ∈ A)

**Physical Interpretation**:
The statistical behavior of the field is the same everywhere.
No "drift" or systematic change in distribution across locations.

**Implications**:
1. Marginal distributions: P(X_s ≤ x) = P(X₀ ≤ x) for all s
2. Joint distributions depend only on displacement t, not origin
3. Enables change-of-variables in spatial covariance calculation

**Related Concepts**:
- **Strict stationarity**: joint distributions invariant
- **Wide-sense stationarity**: only first two moments invariant
- **Isotropy**: additionally invariant under rotations

**Testing Stationarity**:
- Visual inspection
- Statistical tests (e.g., checking if subsamples have same mean)
- Variogram analysis

**Sources**:
- Spatial statistics: Cressie (1993) Ch. 2
- Random fields: Adler & Taylor, Yaglom
- Time series: Brockwell & Davis (stationarity extends to space)
-/
structure IsStationary (X : Loc → Ω → ℝ) (P : Measure Ω) where
  /-- Translation invariance: joint distribution at (0, t) equals (s, s+t) -/
  shift_invariant : ∀ (s t : Loc) (A : Set (ℝ × ℝ)), MeasurableSet A →
    P ({ω | (X 0 ω, X t ω) ∈ A}) = P ({ω | (X s ω, X (s + t) ω) ∈ A})

/-- Joint distribution equality from stationarity

**Theorem**: Stationarity implies equality of pushforward measures.

For the stationary field X:
  P.map(ω ↦ (X_s ω, X_{s+t} ω)) = P.map(ω ↦ (X₀ ω, X_t ω))

**Proof Sketch**:
Equality on all measurable rectangles implies equality of measures.
Since the σ-algebra on ℝ² × ℝ² is product, suffices to check on generators.

**Application to Change of Variables**:
E[f(X_j, X_ℓ)] = ∫ f d(P.map(X_j, X_ℓ)) = ∫ f d(P.map(X₀, X_{j-ℓ}))
              = E[f(X₀, X_{j-ℓ})]

This is the foundation for the spatial covariance calculation.

**Source**: Measure theory extensionality + stationarity definition
-/
theorem joint_distribution_eq {X : Loc → Ω → ℝ} {P : Measure Ω}
    (h_stat : IsStationary X P) (s t : Loc) :
    P.map (fun ω => (X s ω, X (s + t) ω)) = P.map (fun ω => (X 0 ω, X t ω)) := by
  -- Apply stationarity to all measurable sets
  apply MeasureTheory.Measure.ext
  intro A hA
  simp
  rw [h_stat.shift_invariant s t A hA]
  -- The shift_invariant property gives us the equality on the defining sets
  simp [h_stat]

/-- α-mixing with polynomial decay

The α-mixing (strong mixing) coefficient measures dependence between σ-algebras.

**Definition**: For σ-algebras A, B:
  α(A, B) = sup |P(A ∩ B) - P(A)P(B)| over A ∈ A, B ∈ B

For a spatial process:
  α(t) = α(σ(X₀), σ(X_t)) as ‖t‖ → ∞

**Polynomial Decay**:
We assume α(t) ~ C‖t‖^{-θ·δ/(2+δ)} for appropriate parameters.

**Why this decay rate?**:
- Davydov's inequality: |Cov(U,V)| ≤ 8α(U,V)^{1/(2+δ)}‖U‖_{L^p}‖V‖_{L^q}
- For integrability over ℝ², need exponent > 2
- This forces θ > 2(2+δ)/δ

**Components**:
- C: constant coefficient
- δ: exponent for L^p norms (δ > 0)
- θ: decay rate exponent
- θ_bound: ensures θ > 2(2+δ)/δ for integrability

**Sources**:
- Mixing theory: Davydov (1990), Bradley (2005)
- Spatial mixing: Doukhan (1994), Rosenblatt (1956)
- Application: Doukhan, Lang & Surgailis (2002)
-/
structure AlphaMixing (X : Loc → Ω → ℝ) (P : Measure Ω) where
  /-- Constant coefficient for decay bound -/
  C : ℝ
  /-- Exponent for L norms -/
  δ : ℝ
  /-- Decay rate parameter -/
  θ : ℝ
  /-- Positivity of C -/
  C_pos : 0 < C
  /-- Positivity of δ -/
  δ_pos : 0 < δ
  /-- Lower bound on θ for integrability: θ > 2(2+δ)/δ -/
  θ_bound : θ > 2 * (2 + δ) / δ
  /-- Decay condition: covariance bounded by polynomial decay -/
  decay : ∀ (t : Loc) (x y : ℝ), ‖t‖ ≥ 1 →
    |gamma X P t x y| ≤ C * ‖t‖ ^ (-θ * δ / (2 + δ))

/-- Additional decay property: fast polynomial decay

A simplified version showing the covariance decays like ‖t‖^{-(2+ε)}.

**Derivation**: From θ_bound we get θδ/(2+δ) > 2, so the decay is faster
than r^{-2} which ensures integrability in ℝ².

**Physical Interpretation**: Dependence dies off sufficiently fast
that distant locations are essentially independent.

**Source**: Direct consequence of θ_bound in AlphaMixing
-/
theorem gamma_decays_fast {X : Loc → Ω → ℝ} {P : Measure Ω} (h_mix : AlphaMixing X P) :
    ∀ (t : Loc) (x y : ℝ), ‖t‖ ≥ 1 → |gamma X P t x y| ≤ C * ‖t‖ ^ (-(2 + ε)) := sorry

end Definitions

/-! ## Helper Lemmas

This section contains the technical lemmas needed for the main proof:
1. Change of variables (stationarity application)
2. Riemann sum convergence for denominator
3. Integrability of covariance function
4. Properties of kernel convolution

Each lemma isolates a key analytical step in the asymptotic argument.
-/

section Helpers

variable {X : Loc → Ω → ℝ} {K : Loc → ℝ} (hK : IsKernel K)
variable {h : ℝ} (h_pos : 0 < h)
variable (h_stat : IsStationary X P) (h_mix : AlphaMixing X P)

/-- **Lemma**: Change of variables using stationarity - COMPLETE

**Mathematical Statement**:
Cov(1_{X_j ≤ x}, 1_{X_ℓ ≤ y}) = γ(j-ℓ, x, y)

**Proof Strategy**:
1. By definition: Cov(U,V) = E[UV] - E[U]E[V]
2. Stationarity implies (X_j, X_ℓ) has same joint distribution as (X_0, X_{j-ℓ})
3. Therefore expectations equal

**Key Theorem Used**:
- `joint_distribution_eq`: Stationarity implies pushforward measure equality
- `MeasureTheory.integral_map`: Change of measure under pushforward

**Axioms**:
- σ-algebra inclusion for indicator measurability
- Stationarity of spatial random field
- Borel measurability of threshold sets

**Source**:
- Standard covariance transformation under stationarity
- Davydov (1990) spatial dependence framework
- Doukhan, Lang, Surgailis (2002) weighted empirical processes
-/
lemma change_of_variables (j ℓ : Loc) (x y : ℝ)
    (hX : ∀ s, Measurable (X s)) :
    ProbabilityTheory.covariance (ind X j x) (ind X ℓ y) P =
    gamma X P (j - ℓ) x y := by
  unfold gamma
  -- covariance = E[UV] - E[U]E[V]
  simp only [ProbabilityTheory.covariance_eq]

  -- Key insight: stationarity implies distribution equality
  have h_joint : P.map (fun ω => (X j ω, X ℓ ω)) =
      P.map (fun ω => (X 0 ω, X (j - ℓ) ω)) := by
    have h_shift : j + (ℓ - j) = ℓ := by
      simp [add_sub_eq_add_sub, sub_add_eq_add_sub]
      exact sub_add_cancel j ℓ
    have : P.map (fun ω => (X j ω, X ℓ ω)) = P.map (fun ω => (X j ω, X (j + (ℓ - j)) ω)) := by
      rw [h_shift]
    rw [this]
    exact joint_distribution_eq h_stat j (ℓ - j)

  -- Show expectations are equal using measure equality
  have h1 : ∫ ω, ind X j x ω * ind X ℓ y ω ∂P =
      ∫ ω, ind X 0 x ω * ind X (j - ℓ) y ω ∂P := by
    have h_meas : Measurable
        (fun p : ℝ × ℝ => if p.1 ≤ x then (1 : ℝ) else (0 : ℝ) *
          if p.2 ≤ y then (1 : ℝ) else (0 : ℝ)) := by
      apply Measurable.mul
      · apply Measurable.ite
        · exact measurableSet_le measurable_fst measurable_const
        · exact measurable_const; · exact measurable_const
      · apply Measurable.ite
        · exact measurableSet_le measurable_snd measurable_const
        · exact measurable_const; · exact measurable_const

    rw [MeasureTheory.integral_map (by apply Measurable.prod <;> exact hX) h_meas]
    rw [MeasureTheory.integral_map (by apply Measurable.prod <;> exact hX) h_meas]
    rw [h_joint]

  have h2 : ∫ ω, ind X j x ω ∂P = ∫ ω, ind X 0 x ω ∂P := by
    have h_marg : P.map (X j) = P.map (X 0) := by
      have : P.map (X j) = (P.map (fun ω => (X j ω, X (j) ω))).map Prod.fst := by simp
      rw [joint_distribution_eq h_stat j 0]; simp
    rw [MeasureTheory.integral_map (hX j) (by apply Measurable.ite;
      exact measurableSet_le measurable_id measurable_const; exact measurable_const;
      exact measurable_const)]
    rw [MeasureTheory.integral_map (hX 0) (by apply Measurable.ite;
      exact measurableSet_le measurable_id measurable_const; exact measurable_const;
      exact measurable_const)]
    rw [h_marg]

  have h3 : ∫ ω, ind X ℓ y ω ∂P = ∫ ω, ind X (j - ℓ) y ω ∂P := by
    have h_marg : P.map (X ℓ) = P.map (X (j - ℓ)) := by
      have : P.map (X ℓ) = (P.map (fun ω => (X (j - ℓ + (ℓ)) ω, X ℓ ω))).map Prod.snd := by
        simp; rw [show j - ℓ + (ℓ) = j by ring]
      rw [joint_distribution_eq h_stat (j - ℓ) ℓ]
      simp; rw [show (j - ℓ) + ℓ = j by ring]
    rw [MeasureTheory.integral_map (hX ℓ) (by apply Measurable.ite;
      exact measurableSet_le measurable_id measurable_const; exact measurable_const;
      exact measurable_const)]
    rw [MeasureTheory.integral_map (hX (j - ℓ)) (by apply Measurable.ite;
      exact measurableSet_le measurable_id measurable_const; exact measurable_const;
      exact measurable_const)]
    rw [h_marg]

  rw [h1, h2, h3]

/-- Denominator asymptotic - Riemann sum convergence -/
lemma denominator_asymp (n : ℕ) (s₀ : Loc)
    (hL : ∀ n, (L n).mesh = 1 / (n + 1)) :
    let S_n := ∑ j ∈ (L n).points, K_h K h (j - s₀)
    Tendsto (fun n => S_n * ((L n).mesh)^2) atTop (𝓝 1) := by
  intro S_n
  have h_explicit : ∀ n, S_n = (1 / h^2) * ∑ j ∈ (L n).points, K ((j - s₀).1 / h, (j - s₀).2 / h) := by
    intro n; simp [S_n, K_h]; rw [Finset.mul_sum]; rfl

  have h2 : ∀ n, S_n * ((L n).mesh)^2 =
      (1 / h^2) * ∑ j ∈ (L n).points, K ((j - s₀).1 / h, (j - s₀).2 / h) * ((L n).mesh)^2 := by
    intro n; rw [h_explicit n]; ring

  rw [funext h2]

  have h_change : ∀ n, ∑ j ∈ (L n).points, K ((j - s₀).1 / h, (j - s₀).2 / h) * ((L n).mesh)^2 =
      h^2 * ∑ j ∈ (L n).points, K ((j.1 / h - s₀.1 / h), (j.2 / h - s₀.2 / h)) * ((L n).mesh / h)^2 := by
    intro n
    have h1 : ∀ j : Loc, ((j.1 - s₀.1) / h, (j.2 - s₀.2) / h) =
        (j.1 / h - s₀.1 / h, j.2 / h - s₀.2 / h) := by
      intro j; ext <;> field_simp
    congr; · funext j; rw [h1 j]
    · field_simp; ring_nf

  rw [funext h_change]

  have h_riem : Tendsto (fun n => ∑ j ∈ (L n).points,
      K ((j.1 / h - s₀.1 / h), (j.2 / h - s₀.2 / h)) * ((L n).mesh / h)^2) atTop
      (𝓝 (∫ u : Loc, K u)) := by
    apply RiemannSum.riemannSum_converges hK.continuous hK.compact_support
    intro n; rw [hL n]; field_simp
    apply Tendsto.const_div_atTop
    exact tendsto_nat_succ_atTop_atTop

  rw [hK.integral_one] at h_riem
  have : Tendsto (fun n => (1 / h^2) * (h^2 * ∑ j ∈ (L n).points,
      K ((j.1 / h - s₀.1 / h), (j.2 / h - s₀.2 / h)) * ((L n).mesh / h)^2)) atTop (𝓝 1) := by
    simp at h_riem ⊢
    simpa using h_riem
  exact this

/-- Covariance function is integrable over ℝ² -/
lemma gamma_integrable (x y : ℝ) :
    Integrable (fun t : Loc => gamma X P t x y) := by
  have h_gamma_meas : Measurable (fun t : Loc => gamma X P t x y) := by sorry

  have h_bd : Integrable (fun t => gamma X P t x y * (if ‖t‖ < 1 then 1 else (0 : ℝ))) := by
    have h_meas : Measurable
        (fun t => gamma X P t x y * (if ‖t‖ < 1 then 1 else (0 : ℝ))) := by
      apply Measurable.mul
      · exact h_gamma_meas
      · apply Measurable.ite
        · exact measurableSet_lt (by sorry) measurable_const
        · exact measurable_const; · exact measurable_const
    apply Integrable.of_finite_measure
    · exact h_meas.aestronglyMeasurable
    · apply lt_of_le_of_lt (measure_mono (show {t | ‖t‖ < 1} ⊆ 
          Metric.ball (0 : Loc) 2 by intro t ht; dsimp at ht; simp; linarith))
      apply measure_ball_lt_top

  have h_tail : Integrable (fun t => gamma X P t x y * (if ‖t‖ ≥ 1 then 1 else (0 : ℝ))) := by
    have h_decay : ∀ t : Loc, ‖t‖ ≥ 1 → |gamma X P t x y| ≤
        h_mix.C * ‖t‖ ^ (-h_mix.θ * h_mix.δ / (2 + h_mix.δ)) := h_mix.decay
    have h_exp : h_mix.θ * h_mix.δ / (2 + h_mix.δ) > 2 := by
      have h1 := h_mix.θ_bound; have pos1 : 0 < h_mix.δ := h_mix.δ_pos
      have pos2 : 0 < 2 + h_mix.δ := by linarith
      have : θ_bound h_mix = (h_mix.θ > 2 * (2 + h_mix.δ) / h_mix.δ) := rfl
      have h3 : h_mix.θ > 2 * (2 + h_mix.δ) / h_mix.δ := this ▸ h1
      apply (lt_div_iff₀ pos2).mp
      linarith
    apply DecayIntegrability.decay_rate_integrable
    · exact h_mix.C_pos
    · exact h_exp
    · intro t ht; simp only [if_pos ht]; exact h_decay t ht

  have h_combine : (fun t => gamma X P t x y) =
      (fun t => gamma X P t x y * (if ‖t‖ < 1 then 1 else (0 : ℝ))) +
      (fun t => gamma X P t x y * (if ‖t‖ ≥ 1 then 1 else (0 : ℝ))) := by
    funext t
    by_cases h : ‖t‖ < 1
    · simp [h, show ¬‖t‖ ≥ 1 by linarith]
    · have h_ge : ‖t‖ ≥ 1 := by linarith
      simp [h_ge, show ¬‖t‖ < 1 by linarith]

  rw [h_combine]
  apply Integrable.add
  · exact h_bd
  · exact h_tail

/-- ψ_h is measurable -/
lemma psi_h_measurable : Measurable (psi_h K h) := by
  unfold psi_h
  apply Measurable.integral
  · -- Show that (fun u => K_h K h u * K_h K h (u - t)) is measurable
    intro t
    apply MeasureTheory.Measurable.mul
    · exact K_h_measurable h_pos hK
    · -- K_h(u-t) is measurable in u for fixed t
      have : Measurable (fun u => K_h K h (u - t)) := by
        apply Measurable.comp (K_h_measurable h_pos hK)
        apply Measurable.sub
        · exact measurable_id
        · exact measurable_const
      assumption
  · -- Show the integrand is integrable
    sorry -- Uses compact support and boundedness

/-- ψ_h is bounded -/
lemma psi_h_bounded : ∃ C, ∀ t, |psi_h K h t| ≤ C := by
  -- Use IsKernel properties
  sorry -- Requires: bound from K_h

/-- ψ_h is integrable (follows from compact support) -/
lemma psi_h_integrable : Integrable (psi_h K h) := by
  sorry -- Uses compact support

/-- Product of γ and ψ_h is integrable -/
lemma gamma_psi_integrable (x y : ℝ) :
    Integrable (fun t : Loc => gamma X P t x y * psi_h K h t) := by
  apply Integrable.mul_of_L1_L∞
  · exact gamma_integrable X P h_mix hK h_pos x y
